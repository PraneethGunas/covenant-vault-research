{
  "mcpServers": {
    "mcp-pandoc": {
      "command": "uvx",
      "args": ["mcp-pandoc"]
    },
    "bibliography": {
      "command": "node",
      "args": ["/Users/praneeth/bibliography-mcp/dist/index.js"]
    },
    "mcp-mermaid": {
      "command": "npx",
      "args": ["-y", "mcp-mermaid"]
    },
    "arxiv-latex-mcp": {
      "command": "uvx",
      "args": ["arxiv-latex-mcp"]
    },
    "doi-mcp": {
      "command": "npx",
      "args": ["-y", "github:tfscharff/doi-mcp"]
    },
    "paper-search-mcp": {
      "command": "uvx",
      "args": ["--from", "paper-search-mcp", "python", "-c", "from paper_search_mcp.server import mcp; mcp.run()"],
      "env": {
        "PAPER_SEARCH_MCP_UNPAYWALL_EMAIL": ""
      }
    }
  }
}
